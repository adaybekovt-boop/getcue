{
  // Cloudflare Worker (full app): serves the SPA from client/dist and runs the
  // entire /api on the edge, backed by D1. Includes the admin multi-platform chat
  // (OpenRouter + Groq + Gemini), vision, and image generation. The pre-port
  // version is preserved at worker/index.js.archived.
  //
  // Required secrets (set with `wrangler secret put <NAME>`):
  //   BOT_TOKEN, WEBHOOK_SECRET, ADMIN_TELEGRAM_IDS, ADMIN_CHAT_TOKEN,
  //   OPENROUTER_USER_KEY, OPENROUTER_ADMIN_KEY, GEMINI_API_KEYS,
  //   GROQ_GPT_KEY, GROQ_QWEN_KEY, GROQ_META_KEY,
  //   GEMINI_FLASH_LITE_KEY, GEMINI_FLASH_KEY, GEMINI_FRONTIER_KEY, GEMINI_IMAGE_KEY
  // After deploy, apply the D1 migrations (adds platform/effort columns):
  //   wrangler d1 migrations apply getcue --remote
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "getcue",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-07",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "4779193285f4b7225a52cfb160958347",
  "assets": {
    "directory": "./client/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "getcue",
      "database_id": "0c8af186-3982-4a2a-b456-087ebd99ae68",
      "migrations_dir": "./migrations"
    }
  ],
  "vars": {
    "NODE_ENV": "production"
  }
}
