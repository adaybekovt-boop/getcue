GEMINI_API_KEYS=key1,key2,key3,key4,key5
GEMINI_API_KEY=                         # fallback if GEMINI_API_KEYS is not set
SILICONFLOW_API_KEYS=sk-key1,sk-key2    # comma-separated, optional fallback provider
SILICONFLOW_API_TOKEN=                  # single key fallback
QWEN_API_KEY=                           # Qwen/Alibaba DashScope key (compatible-mode)
OPENROUTER_USER_KEY=                    # OpenRouter user traffic: GPT-OSS 20B text + Gemma 4 vision
OPENROUTER_ADMIN_KEY=                   # OpenRouter admin traffic: full model choice / admin chat
ADMIN_CHAT_TOKEN=                       # secret to unlock hidden admin chat; prod: wrangler secret put
ADMIN_PANEL_TOKEN=                      # secret to unlock the admin monitoring panel; uses a built-in default if unset
GITHUB_TOKEN=                           # optional; raises GitHub API limit from 60 to 5000 req/hr
BOT_TOKEN=                              # Telegram bot token from @BotFather
ADMIN_TELEGRAM_IDS=123456789,987654321
PORT=3000
DB_PATH=./data/cue.db
WEBHOOK_SECRET=change-me-to-a-long-random-string
